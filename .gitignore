# =============================================================================
# pyAlienFX .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# pip
# -----------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.tox/
.nox/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Type checkers & linters
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# pyAlienFX runtime files
# -----------------------------------------------------------------------------
# USB packet debug log written by AlienFXEngine at runtime
packet.log

# Generated launcher / bin scripts written by install.py
pyAlienFX_Launcher.sh
pyAlienFX

# User profile configs (runtime data, not source)
Profiles/

# -----------------------------------------------------------------------------
# Generated installer artifacts
# -----------------------------------------------------------------------------
*.desktop
